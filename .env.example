OPENAI_API_KEY=sk-...
TELEGRAM_BOT_TOKEN=1234567890:telegram-token
BOT_MODE=polling
BOT_PUBLIC_URL=https://your-bot.example.com
BOT_WEBHOOK_SECRET=change-me
OPENAI_MODEL=gpt-5-mini
OPENAI_FALLBACK_MODEL=gpt-5
SYSTEM_PROMPT=You are a helpful Telegram assistant. Be concise, accurate, and action-oriented.
ALLOWED_USER_IDS=
DATABASE_PATH=data/bot.sqlite3
MAX_CONTEXT_MESSAGES=16
MAX_CONCURRENT_USER_TASKS=1
LONG_TASK_THRESHOLD_SECONDS=8
PORT=8080
